<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Voice Assistant</title>
  <style>
    body { background:#eceff1; display:flex; justify-content:center; align-items:center; height:100vh; font-family:Arial, sans-serif; }
    .chat-container { width:420px; height:90vh; background:white; border-radius:15px; overflow:hidden;
      display:flex; flex-direction:column; box-shadow:0 5px 20px rgba(0,0,0,0.15); }
    .chat-header { background:#007bff; color:white; padding:18px; text-align:center; font-size:20px; font-weight:bold; }
    .chat-body { flex:1; padding:15px; overflow-y:auto; background:#f5f7fb; }
    .message { margin-bottom:15px; display:flex; flex-direction:column; }
    .user-message { align-items:flex-end; }
    .bot-message { align-items:flex-start; }
    .bubble { max-width:85%; padding:14px; border-radius:15px; line-height:1.7; font-size:15px; }
    .user-message .bubble { background:#007bff; color:white; border-bottom-right-radius:5px; }
    .bot-message .bubble { background:white; color:#333; border:1px solid #ddd; border-bottom-left-radius:5px; }
    .controls { padding:10px; display:flex; flex-direction:column; gap:8px; border-top:1px solid #eee; }
    select { padding:10px; border-radius:8px; border:1px solid #ccc; font-size:14px; }
    button { padding:12px; border:none; border-radius:8px; background:#007bff; color:white; font-size:15px; cursor:pointer; }
    button:hover { background:#0056b3; }
  </style>
</head>
<body>
  <div class="chat-container">
    <div class="chat-header">Voice Assistant</div>
    <div class="chat-body" id="chatBody">
      <div class="message bot-message">
        <div class="bubble">Hello 👋 Select your language, then tap mic to speak.</div>
      </div>
    </div>
    <div class="controls">
      <!-- KEY FIX: User picks language so SpeechRecognition transcribes correctly -->
      <select id="langSelect">
        <option value="en-IN">English</option>
        <option value="ta-IN">Tamil</option>
        <option value="hi-IN">Hindi</option>
        <option value="te-IN">Telugu</option>
        <option value="kn-IN">Kannada</option>
      </select>
      <button onclick="startVoice()">🎤 Speak</button>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {

      async function startVoice() {
        const selectedLang = document.getElementById("langSelect").value;

        const recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)();

        // ✅ KEY FIX: Use selected language, not hardcoded en-IN
        recognition.lang = selectedLang;
        recognition.continuous = false;
        recognition.interimResults = false;

        recognition.onstart = () => console.log("🎤 Listening in", selectedLang);

        recognition.onresult = async event => {
          const text = event.results[0][0].transcript;
          const chatBody = document.getElementById("chatBody");

          // Show user message
          const userDiv = document.createElement("div");
          userDiv.className = "message user-message";
          userDiv.innerHTML = `<div class="bubble">${text}</div>`;
          chatBody.appendChild(userDiv);

          try {
            const response = await fetch("http://127.0.0.1:5000/voice-reply", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ userId: 1, message: text })
            });

            const data = await response.json();

            // Show bot reply
            const botDiv = document.createElement("div");
            botDiv.className = "message bot-message";
            botDiv.innerHTML = `<div class="bubble">${data.reply}</div>`;
            chatBody.appendChild(botDiv);

            // Play audio
            if (data.audio) {
              const audio = new Audio("http://127.0.0.1:5000" + data.audio);
              audio.play();
            }

          } catch (err) {
            console.error("Fetch error:", err);
            const errDiv = document.createElement("div");
            errDiv.className = "message bot-message";
            errDiv.innerHTML = `<div class="bubble">⚠️ Could not reach server.</div>`;
            chatBody.appendChild(errDiv);
          }

          chatBody.scrollTop = chatBody.scrollHeight;
        };

        recognition.onerror = err => {
          console.error("Voice error:", err.error);
          alert("Voice error: " + err.error);
        };

        recognition.start();
      }

      window.startVoice = startVoice;
    });
  </script>
</body>
</html>
